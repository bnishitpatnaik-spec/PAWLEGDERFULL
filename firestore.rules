rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    match /users/{uid} {
      allow read, create: if isOwner(uid);
      allow update, delete: if false; // user profile updates should go through controlled flows
    }

    match /pets/{petId} {
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.petId == petId;

      allow read, update, delete: if isOwner(resource.data.ownerId);
    }
  }
}

